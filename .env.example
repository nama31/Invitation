# Root .env — copy to .env and fill in your values
# ─────────────────────────────────────────────────
DOMAIN=yourdomain.com
# PostgreSQL
POSTGRES_USER=eventinvite
POSTGRES_PASSWORD=secret
POSTGRES_DB=eventinvite

# Backend
DATABASE_URL=postgresql+asyncpg://eventinvite:secret@postgres:5432/eventinvite
JWT_SECRET=change_me_in_production
JWT_EXPIRE_MINUTES=60

# Event details
EVENT_NAME=Our Event
EVENT_DATE=2025-09-14T18:00:00

# Admin seed credentials
ADMIN_EMAIL=admin@event.com
ADMIN_PASSWORD=change_me

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Cloudflare R2 (required for photo gallery)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=eventinvite-photos
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
\nNEXT_PUBLIC_PHOTOS_FOLDER_URL=https://disk.yandex.com/d/your-folder-link
